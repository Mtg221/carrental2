# Server Configuration
PORT=3001

# MongoDB Atlas Connection String
# Remplace <username> et <password> par tes identifiants MongoDB
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/carrental?retryWrites=true&w=majority

# JWT Secret (au moins 32 caractères)
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_secure_jwt_secret_here

# Client URL (pour CORS)
CLIENT_URL=http://localhost:3000

# Node Environment
NODE_ENV=development
